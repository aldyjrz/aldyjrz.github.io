# Cloudflare Workers Configuration

# KV Namespace IDs (dapatkan dari: wrangler kv:namespace create)
KV_NAMESPACE_ID=your-kv-namespace-id
KV_PREVIEW_ID=your-kv-preview-id

# R2 Bucket Names
R2_BUCKET_NAME=portfolio-uploads
R2_PREVIEW_BUCKET_NAME=portfolio-uploads-preview

# Environment
ENVIRONMENT=production

# API URLs (jika perlu)
API_URL=https://your-worker-url.workers.dev
